# Supabase: Project Settings → Database → Connection string (URI).
# DATABASE_URL: pooler (e.g. port 6543) for app runtime — avoids exhausting DB connections.
# DIRECT_URL: direct Postgres (e.g. port 5432) for prisma migrate / db push — avoids pgbouncer prepared-statement issues.
# Server-only: never expose these to the browser (Next.js: use only in server code / Route Handlers).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# Random string (min 16 chars) for signing admin session cookies. Server-only.
SESSION_SECRET="change-me-to-a-long-random-secret"

# Optional: override default super-admin created by `npm run db:seed` (dev defaults: wego-super / WegoDev2026!Aa)
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=

# E2E (Playwright) — credentials are stored ONLY in .env.local (do not commit)
E2E_ADMIN_USERNAME=
E2E_ADMIN_PASSWORD=
