// Admin / employee management — data layer only.
// Uses soft deletes where specified; no hard deletes for critical business rows in app logic (enforced later).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum OrderStatus {
  OPEN
  CANCELLED
  WAITING_FOR_EXECUTION
  WITHDRAWAL_FROM_SUPPLIER
  SENT
  WAITING_FOR_CHINA_EXECUTION
  COMPLETED
  DEBT_WITHDRAWAL
}

/** מקור / יעד רכש להזמנה (ניהול וטבלת הזמנות) */
enum OrderSourceCountry {
  TURKEY
  CHINA
  UAE
  JORDAN
}

/** סביבת עבודה לפי מדינה — TR/CN/AE (מספור CH; JO legacy בלבד) */
enum WorkCountryCode {
  TR
  CN
  AE
  JO
}

enum OrderEditRequestStatus {
  PENDING
  APPROVED
  REJECTED
  /** נוצלה לאחר עריכה בפועל לאחר אישור */
  USED
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalRequestType {
  INVOICE_CANCEL
}

enum PaymentMethod {
  POINT
  BANK_TRANSFER
  BANK_TRANSFER_DONE
  ORDERED
  WITHDRAWAL
  WITHDRAWAL_DONE
  RECEIVED_AT_POINT
  WITH_GOODS
  CHECK
  CASH
  CREDIT
  OTHER
}

/** סטטוס צ׳יק בקליטה ובטבלת מקור */
enum PaymentCheckStatus {
  PENDING
  DEPOSITED
  BOUNCED
}

/** סטטוס קליטת תשלום — ביטול ללא מחיקה */
enum PaymentRecordStatus {
  ACTIVE
  CANCELLED
}

model User {
  id           String    @id @default(uuid())
  fullName     String
  email        String?   @unique
  username     String?   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  permissions     UserPermission[]
  createdOrders   Order[]          @relation("OrderCreatedBy")
  createdPayments   Payment[] @relation("PaymentCreatedBy")
  cancelledPayments Payment[] @relation("PaymentCancelledBy")
  receiptControls ReceiptControl[] @relation("ReceiptControlCreatedBy")
  auditLogs       AuditLog[]
  legacyImports   LegacyRawRow[]    @relation("LegacyImportUser")
  financialSettingsUpdates FinancialSettings[]
  orderEditRequestsRequested OrderEditRequest[] @relation("OrderEditRequestRequestedBy")
  orderEditRequestsApproved  OrderEditRequest[] @relation("OrderEditRequestApprovedBy")
  orderEditRequestsRejected  OrderEditRequest[] @relation("OrderEditRequestRejectedBy")
  approvalRequestsRequested  ApprovalRequest[]  @relation("ApprovalRequestRequestedBy")
  approvalRequestsApproved   ApprovalRequest[]  @relation("ApprovalRequestApprovedBy")
  approvalRequestsRejected   ApprovalRequest[]  @relation("ApprovalRequestRejectedBy")
  ordersEditUnlockedFor      Order[]            @relation("OrderEditUnlockFor")
  paymentPlansCreated        PaymentPlan[]      @relation("PaymentPlanCreatedBy")
  notifications              UserNotification[]
  cashExpenses               CashExpense[]      @relation("CashExpenseCreatedBy")
  cashCountsCreated          CashCount[]        @relation("CashCountCreatedBy")
  cashCountsApproved         CashCount[]        @relation("CashCountApprovedBy")
  paymentCashAuditReviews    PaymentCashAuditReview[] @relation("PaymentCashAuditReviewBy")
  cashDailyDrawerCounts      CashDailyDrawerCount[]   @relation("CashDailyDrawerCountBy")
  cashWeekFlowsUpdated       CashWeekFlow[]           @relation("CashWeekFlowBy")
  turkeyTransferMovements  TurkeyTransferMovement[] @relation("TurkeyTransferMovementBy")
  paymentAdjustmentFeesCreated PaymentAdjustmentFee[] @relation("PaymentAdjustmentFeeCreatedBy")
  paymentAdjustmentFeesClosed  PaymentAdjustmentFee[] @relation("PaymentAdjustmentFeeClosedBy")
  inventoryCountsCreated   InventoryCount[]         @relation("InventoryCountCreatedBy")
}

/** הגדרות שער דולר גלובליות: בסיס (usd_rate_base), עמלה (usd_fee), שער סופי מחושב (usd_rate_final). */
model FinancialSettings {
  id                       String   @id @default(cuid())
  baseDollarRate           Decimal  @db.Decimal(10, 4)
  dollarFee                Decimal  @db.Decimal(10, 4) @default(0)
  finalDollarRate          Decimal  @db.Decimal(10, 4)
  /** אחוז עמלה ברירת מחדל לקליטת הזמנה חדשה (למשל 3.45) */
  defaultCommissionPercent Decimal  @default(0) @db.Decimal(7, 4)
  source                   String   @default("MANUAL")
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedBy User? @relation(fields: [updatedById], references: [id])
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userPermissions UserPermission[]
}

model UserPermission {
  id           String   @id @default(uuid())
  userId       String
  permissionId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

model Customer {
  id              String    @id @default(uuid())
  oldCustomerCode String?
  customerCode    String?   @unique
  nameHe          String?
  nameAr          String?
  nameEn          String?
  displayName     String
  phone           String?
  phone2          String?   @map("secondPhone")
  country         String?
  email           String?
  city            String?
  region          String?
  address         String?
  notes           String?
  /** סוג לקוח (מערכת ישנה): רגיל / סיטונאי / סוכן וכו׳ */
  customerType    String?
  /** Snapshot יתרת לקוח ב-USD: totalPayments - totalOrders. חיובי = זכות, שלילי = חוב */
  balanceUsd      Decimal   @default(0) @db.Decimal(19, 4)
  /** הפרדת סביבות — ברירת מחדל TR לנתונים קיימים */
  countryCode     WorkCountryCode @default(TR)
  isActive        Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders          Order[]
  payments        Payment[]
  receiptControls ReceiptControl[]
  paymentPlans    PaymentPlan[]
  paymentAdjustmentFees PaymentAdjustmentFee[]

  @@index([countryCode])
  @@index([countryCode, customerCode])
  @@index([countryCode, oldCustomerCode])
  @@index([displayName])
  @@index([nameHe])
  @@index([nameAr])
  @@index([nameEn])
  @@index([phone])
  @@index([phone2])
  @@index([country])
  @@index([oldCustomerCode])
  @@index([isActive, createdAt])
  @@index([createdAt])
  @@index([city])
}

model Order {
  id                   String         @id @default(uuid())
  oldOrderNumber       String?
  orderNumber          String?        @unique
  /** מזהה הזמנה חיצוני (מערכת מקור — למשל טורקיה). לייבוא והתאמת מערכות; ייחודי כשקיים. */
  externalOrderId      String?
  /** סניף מקור מתוך דוח חיצוני (לא לוגיקה — שדה מידע) */
  branch               String?
  /** גובה / אחראי גבייה מתוך דוח חיצוני (לא לוגיקה — שדה מידע) */
  collector            String?
  customerId           String?
  customerCodeSnapshot String?
  customerNameSnapshot String?
  customerTypeSnapshot String?
  weekCode             String?
  /** מדינת ספק / מקור עסקה — מתוך רשימה מוגדרת בהגדרות */
  sourceCountry        OrderSourceCountry?
  /** סביבת עבודה — מסנן וממוספר לפי מדינה */
  countryCode          WorkCountryCode @default(TR)
  orderDate            DateTime?
  /** תאריך ביצוע ההזמנה בפועל (בתוך טווח השבוע) */
  orderExecutionDate   DateTime?
  /** תאריך ושעת קליטת ההזמנה במערכת */
  intakeDateTime       DateTime?
  /** מזהה סטטוס — ערך מ-SourceStatus.id (למשל OPEN או מזהה מותאם) */
  status               String         @default("OPEN")
  paymentMethod        String?
  paymentPointId       String?
  amountUsd            Decimal?       @db.Decimal(19, 4)
  commissionUsd        Decimal?       @db.Decimal(19, 4)
  totalUsd             Decimal?       @db.Decimal(19, 4)
  amountIls            Decimal?       @db.Decimal(19, 4)
  commissionIls        Decimal?       @db.Decimal(19, 4)
  totalIls             Decimal?       @db.Decimal(19, 4)
  exchangeRate         Decimal?       @db.Decimal(19, 6)
  /** אחוז עמלה שנשמר ברגע קליטת ההזמנה (מסמך היסטורי) */
  commissionPercent    Decimal        @default(0) @db.Decimal(7, 4)
  vatRate              Decimal        @default(18) @db.Decimal(7, 4)
  amountWithoutVat     Decimal?       @db.Decimal(19, 4)
  /** צילום שערים בעת יצירת ההזמנה — לא משתנה כשמעדכנים הגדרות כספים */
  snapshotBaseDollarRate   Decimal? @db.Decimal(10, 4)
  snapshotDollarFee        Decimal? @db.Decimal(10, 4)
  snapshotFinalDollarRate  Decimal? @db.Decimal(10, 4)
  /** שער דולר ששימש לחישוב ₪ לשורה (בדרך כלל = snapshotFinalDollarRate) */
  usdRateUsed              Decimal? @map("usd_rate_used") @db.Decimal(10, 4)
  totalIlsWithVat          Decimal? @db.Decimal(19, 4)
  totalIlsWithoutVat       Decimal? @db.Decimal(19, 4)
  vatAmount                Decimal? @db.Decimal(19, 4)
  notes                String?
  /** סימון תפעולי בלבד: הזמנה מוכנה שהסתיימה בפועל (לא סטטוס, לא משפיע חישובים) */
  isCompleted          Boolean        @default(false)
  isActive             Boolean        @default(true)
  deletedAt            DateTime?
  createdById          String?
  /** מקום קליטת הזמנה (FK ל-IntakeLocation). נשמר כעמודה רגילה לאחר ALTER TABLE היסטורי. */
  locationId           String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  /**
   * סכום שנמשך אוטומטית מקרדיט הלקוח ("משיכה מהחוב").
   * זה NULL לכל הזמנה רגילה. עבור הזמנה עם status=DEBT_WITHDRAWAL
   * מאוחסן הסכום שנקזז בפועל מיתרת הזכות של הלקוח
   * (≤ totalUsd וגם ≤ הקרדיט הזמין בעת השמירה).
   * לא נוצר Payment עבור הסכום הזה — הוא משפיע על "שולם" של
   * ההזמנה ישירות, ועל יתרת הלקוח דרך orders − payments הקיים.
   */
  debtWithdrawalUsd     Decimal?       @db.Decimal(19, 4)

  customer     Customer?     @relation(fields: [customerId], references: [id])
  createdBy    User?         @relation("OrderCreatedBy", fields: [createdById], references: [id])
  paymentPoint PaymentPoint? @relation(fields: [paymentPointId], references: [id])
  payments    Payment[]
  paymentAdjustmentFees PaymentAdjustmentFee[]
  /** חלוקת תשלום מורכב — הגדרת פיצול ההזמנה בין אמצעי תשלום (תכנון, לא תשלום בפועל) */
  paymentBreakdown OrderPaymentBreakdown[]
  /** מטא-דאטה לחלוקת תשלום פעילה — שורות בפועל ב-OrderPaymentBreakdown */
  paymentPlan      PaymentPlan?
  /** נפתח זמנית לאחר אישור מנהל לעריכת הזמנה בסטטוס הושלמה */
  editUnlockedForUserId String?
  editUnlockedUntil     DateTime?
  editUnlockedFor       User?              @relation("OrderEditUnlockFor", fields: [editUnlockedForUserId], references: [id])
  editRequests          OrderEditRequest[]

  @@index([oldOrderNumber])
  @@index([externalOrderId])
  @@index([weekCode])
  @@index([orderDate])
  @@index([orderExecutionDate])
  @@index([intakeDateTime])
  @@index([createdAt])
  @@index([status])
  @@index([isCompleted])
  @@index([customerId])
  @@index([paymentPointId])
  @@index([editUnlockedForUserId])
  @@index([weekCode, deletedAt])
  @@index([weekCode, orderNumber])
  @@index([weekCode, oldOrderNumber])
  @@index([sourceCountry])
  @@index([countryCode])
  @@index([countryCode, weekCode])
  @@index([countryCode, sourceCountry, weekCode, deletedAt, customerId])
  @@index([countryCode, sourceCountry, orderDate, deletedAt, customerId])
  @@index([customerId, countryCode, sourceCountry, status])
  @@index([status, orderDate])
}

/**
 * חלוקת "תשלום מורכב" של הזמנה בין אמצעי תשלום.
 * זו הגדרת פיצול מתוכננת (כמה אמור להיגבות בכל אמצעי) — לא תשלום בפועל.
 * התשלומים בפועל נרשמים ב-Payment, ומסך קליטת התשלום מוגבל לאמצעים שכאן.
 * amount/currency: USD או ILS לפי currency. סכום החלוקה חייב להיות שווה לסך ההזמנה.
 */
model OrderPaymentBreakdown {
  id            String   @id @default(uuid())
  orderId       String
  paymentMethod String
  /** סכום מתוכנן במטבע של currency (USD או ILS) — ללא המרה */
  amount        Decimal  @db.Decimal(19, 4)
  currency      String   @default("USD")
  /**
   * סה״כ ששולם לאמצעי זה במטבע של השורה (USD או ILS).
   * Matching Engine מעדכן בנפרד לכל מטבע — אין קיזוז בין מטבעות.
   */
  paidAmount    Decimal  @default(0) @db.Decimal(19, 4) @map("paidUsd")
  /**
   * יתרה פתוחה במטבע של השורה. null = רשומה ישנה;
   * לאחר Matching Engine תמיד מאוכלס.
   */
  remainingAmount Decimal? @db.Decimal(19, 4) @map("remainingUsd")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

enum PaymentPlanStatus {
  ACTIVE
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
  REPLACED
}

enum PaymentPlanClosureType {
  BALANCE_RESET
  CREDIT_BALANCE
  PAYMENT_RECEIVED
}

/**
 * מטא-דאטה לחלוקת תשלום פעילה של הזמנה.
 * שורות החלוקה נשמרות ב-OrderPaymentBreakdown; אין שכפול במעבר שבוע.
 */
model PaymentPlan {
  id                String                  @id @default(uuid())
  orderId           String                  @unique @map("order_id")
  customerId        String                  @map("customer_id")
  /** שבוע מקור ההזמנה בעת יצירת החלוקה */
  sourceWeekCode    String?                 @map("source_week_code")
  /** שבוע שבו נוצרה החלוקה */
  createdInWeekCode String                  @map("created_in_week_code")
  status            PaymentPlanStatus       @default(ACTIVE)
  closureType       PaymentPlanClosureType? @map("closure_type")
  createdById       String?                 @map("created_by_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer  Customer @relation(fields: [customerId], references: [id])
  createdBy User?    @relation("PaymentPlanCreatedBy", fields: [createdById], references: [id])

  @@index([customerId, status])
  @@index([status])
  @@map("payment_plan")
}

enum TurkeyTransferMovementType {
  CASH_COUNT_ALLOCATION
  TRANSFER_TO_TURKEY
  CASH_COUNT_ADJUSTMENT
  TRANSFER_REVERSAL
  MANUAL_ADJUSTMENT
}

enum TurkeyTransferCurrency {
  USD
  ILS
}

/**
 * תנועות יתרה להעברה לטורקיה — מקור האמת.
 * היתרה = סכום תנועות (הקצאות + התאמות − העברות + ביטולים).
 */
model TurkeyTransferMovement {
  id             String                   @id @default(uuid())
  countryCode    WorkCountryCode          @default(TR)
  weekCode       String                   @map("week_code")
  cashWeekFlowId String?                  @map("cash_week_flow_id")
  type           TurkeyTransferMovementType
  currency       TurkeyTransferCurrency
  /** סכום חיובי; סימן נגזר מ-type בחישוב */
  amount         Decimal                  @db.Decimal(19, 4)
  balanceBefore  Decimal?                 @map("balance_before") @db.Decimal(19, 4)
  balanceAfter   Decimal?                 @map("balance_after") @db.Decimal(19, 4)
  reference      String?
  notes          String?
  metadata       Json?
  createdById    String?                  @map("created_by_id")
  createdAt      DateTime                 @default(now()) @map("created_at")

  cashWeekFlow CashWeekFlow? @relation(fields: [cashWeekFlowId], references: [id], onDelete: SetNull)
  createdBy    User?         @relation("TurkeyTransferMovementBy", fields: [createdById], references: [id])

  @@index([countryCode, weekCode])
  @@index([cashWeekFlowId])
  @@index([type])
  @@index([createdAt])
  @@map("turkey_transfer_movement")
}

/// מונה רץ למספור הזמנות לפי שבוע — UPDATE+RETURNING במקום MAX על Order
model OrderWeekCounter {
  weekCode   String   @id @map("week_code")
  nextNumber Int      @default(0) @map("next_number")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("order_week_counter")
}

model OrderEditRequest {
  id                String                 @id @default(uuid())
  orderId           String
  requestedByUserId String
  requestReason     String                 @db.Text
  status            OrderEditRequestStatus @default(PENDING)
  createdAt         DateTime               @default(now())
  approvedAt        DateTime?
  approvedByUserId  String?
  rejectedAt        DateTime?
  rejectedByUserId  String?
  /** ערכי הזמנה לפני השינוי המבוקש */
  beforeSnapshot    Json?
  /** ערכי הזמנה אחרי השינוי המבוקש (תצוגה) */
  afterSnapshot     Json?
  /** payload מלא ליישום בעת אישור */
  proposedPayload   Json?
  rejectionReason   String?                @db.Text

  order       Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  requestedBy User  @relation("OrderEditRequestRequestedBy", fields: [requestedByUserId], references: [id])
  approvedBy  User? @relation("OrderEditRequestApprovedBy", fields: [approvedByUserId], references: [id])
  rejectedBy  User? @relation("OrderEditRequestRejectedBy", fields: [rejectedByUserId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([requestedByUserId])
  @@index([createdAt])
}

model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  kind      String
  title     String
  body      String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model ApprovalRequest {
  id                String                @id @default(uuid())
  type              ApprovalRequestType
  status            ApprovalRequestStatus @default(PENDING)
  paymentId         String
  requestedByUserId String
  cancelReason      String                @db.Text
  notes             String?               @db.Text
  createdAt         DateTime              @default(now())
  approvedAt        DateTime?
  approvedByUserId  String?
  rejectedAt        DateTime?
  rejectedByUserId  String?

  payment     Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  requestedBy User    @relation("ApprovalRequestRequestedBy", fields: [requestedByUserId], references: [id])
  approvedBy  User?   @relation("ApprovalRequestApprovedBy", fields: [approvedByUserId], references: [id])
  rejectedBy  User?   @relation("ApprovalRequestRejectedBy", fields: [rejectedByUserId], references: [id])

  @@index([paymentId])
  @@index([status])
  @@index([type, status])
  @@index([requestedByUserId])
  @@index([createdAt])
}

enum PaymentBusinessType {
  STANDARD
  CUSTOMER_CREDIT
  CREDIT_APPLICATION
  BALANCE_RESET
  ADJUSTMENT_FEE
}

model Payment {
  id               String         @id @default(uuid())
  paymentCode      String?        @unique
  /** מספר קליטה רציף (למשל 92 עבור WGP-P-000092) — ניווט וסדר ERP */
  paymentNumber    Int?
  customerId       String?
  orderId          String?
  countryCode      WorkCountryCode @default(TR)
  weekCode         String?
  paymentDate      DateTime?
  /**
   * תאריך ביצוע קליטת התשלום — מקור האמת לבקרת קופה בלבד.
   * לא משנה שבוע הזמנה / FIFO / סגירת חוב (Payment.weekCode + paymentDate נשארים ללוגיקה העסקית).
   */
  intakeDate       DateTime?
  currency         String         @default("ILS")
  amountUsd        Decimal?       @db.Decimal(19, 4)
  amountIls        Decimal?       @db.Decimal(19, 4)
  /** מטבע המקור שבו שולם בפועל (ILS/USD/MIXED) — בקרה ודוחות */
  sourceCurrency   String?
  /** סכום המקור כפי שהוקלד במטבע המקור (לפני המרה) */
  sourceAmount     Decimal?       @db.Decimal(19, 4)
  exchangeRate     Decimal?       @db.Decimal(19, 6)
  vatRate          Decimal        @default(18) @db.Decimal(7, 4)
  /** אחוז עמלה ששמרנו ברגע הקליטה — תצוגתי/תיעודי, אין לו השפעה על amountUsd ואינו שובר חישובים קיימים */
  commissionPercent Decimal       @default(0) @db.Decimal(7, 4)
  amountWithoutVat Decimal?       @db.Decimal(19, 4)
  snapshotBaseDollarRate  Decimal? @db.Decimal(10, 4)
  snapshotDollarFee       Decimal? @db.Decimal(10, 4)
  snapshotFinalDollarRate  Decimal? @db.Decimal(10, 4)
  totalIlsWithVat          Decimal? @db.Decimal(19, 4)
  totalIlsWithoutVat       Decimal? @db.Decimal(19, 4)
  vatAmount                Decimal? @db.Decimal(19, 4)
  manualDateChanged        Boolean  @default(false)
  paymentMethod    String?
  /** צורת תשלום בדולר (כאשר יש amountUsd) — תאימות לקליטה דו-מטבעית */
  usdPaymentMethod String?
  /** צורת תשלום בשקל (כאשר יש amountIls) */
  ilsPaymentMethod String?
  usdNote          String?
  ilsNote          String?
  paymentPlace     String?
  isPaid           Boolean        @default(false)
  /** ACTIVE = תשלום תקף; CANCELLED = בוטל — לא נספר ביתרות/דוחות */
  status           PaymentRecordStatus @default(ACTIVE)
  /** סוג עסקי מובנה — החלטות עסקיות אינן תלויות עוד בתוכן notes */
  businessType     PaymentBusinessType @default(STANDARD)
  cancelledAt      DateTime?
  cancelledById    String?
  cancelReason     String?
  proofFileUrl     String?
  notes            String?
  createdById      String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  customer    Customer? @relation(fields: [customerId], references: [id])
  order       Order?    @relation(fields: [orderId], references: [id])
  createdBy   User?     @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  cancelledBy User?     @relation("PaymentCancelledBy", fields: [cancelledById], references: [id])
  checks      PaymentCheck[]
  approvalRequests ApprovalRequest[]
  cashAuditReviews PaymentCashAuditReview[]
  paymentAdjustmentFees PaymentAdjustmentFee[]
  methodAllocations PaymentMethodAllocation[]

  @@index([customerId])
  @@index([orderId])
  @@index([countryCode])
  @@index([weekCode])
  @@index([paymentDate])
  @@index([intakeDate])
  @@index([createdAt])
  @@index([isPaid])
  @@index([paymentNumber])
  @@index([status])
  @@index([businessType])
  @@index([paymentDate, isPaid])
  @@index([weekCode, isPaid])
  @@index([countryCode, weekCode, status, isPaid, customerId])
  @@index([countryCode, paymentDate, status, isPaid, customerId])
  @@index([customerId, countryCode, status, isPaid])
}

/** פירוט אמצעי התשלום של קליטה — מקור מובנה במקום פענוח notes */
model PaymentMethodAllocation {
  id           String   @id @default(uuid())
  paymentId    String
  method       String
  currency     String
  sourceAmount Decimal  @db.Decimal(19, 4)
  amountUsd    Decimal  @db.Decimal(19, 4)
  createdAt    DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([method])
  @@index([currency])
  @@map("payment_method_allocation")
}

/**
 * בקרת קופה — הוצאת כסף פיזי מהקופה (₪/$).
 * currency: "ILS" | "USD". reason: FUEL/COURIER/FOOD/SUPPLIER/PURCHASE/OTHER.
 * status: ACTIVE/CANCELLED (ביטול ללא מחיקה — לא נספר בחישוב הקופה).
 */
model CashExpense {
  id          String              @id @default(uuid())
  countryCode WorkCountryCode     @default(TR)
  weekCode    String?
  expenseDate DateTime            @default(now())
  currency    String              @default("ILS")
  amount      Decimal             @db.Decimal(19, 4)
  reason        String              @default("OTHER")
  paymentMethod String              @default("CASH")
  notes         String?
  status      PaymentRecordStatus @default(ACTIVE)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  createdBy User? @relation("CashExpenseCreatedBy", fields: [createdById], references: [id])

  @@index([countryCode])
  @@index([weekCode])
  @@index([expenseDate])
  @@index([status])
  @@index([paymentMethod])
}

/**
 * בקרת קופה — ספירת קופה (snapshot). שומר "אמור להיות" שחושב בעת הספירה,
 * "נספר בפועל" שהוזן, והפער. varianceStatus: OPEN/APPROVED (אישור מנהל לפער).
 */
model CashCount {
  id             String          @id @default(uuid())
  countryCode    WorkCountryCode @default(TR)
  weekCode       String?
  countedAt      DateTime        @default(now())
  expectedIls    Decimal         @db.Decimal(19, 4) @default(0)
  expectedUsd    Decimal         @db.Decimal(19, 4) @default(0)
  countedIls     Decimal         @db.Decimal(19, 4) @default(0)
  countedUsd     Decimal         @db.Decimal(19, 4) @default(0)
  diffIls        Decimal         @db.Decimal(19, 4) @default(0)
  diffUsd        Decimal         @db.Decimal(19, 4) @default(0)
  notes          String?
  varianceNote   String?
  varianceStatus String          @default("OPEN")
  createdById    String?
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  createdBy  User? @relation("CashCountCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("CashCountApprovedBy", fields: [approvedById], references: [id])

  @@index([countryCode])
  @@index([weekCode])
  @@index([countedAt])
}

/**
 * בקרת קופה — סימון "נבדק" לקליטת תשלום (ביקורת בלבד, ללא שינוי עסקי).
 * פר קליטה + שבוע עבודה — נשמר בין רענונים.
 */
model PaymentCashAuditReview {
  id           String   @id @default(uuid())
  paymentId    String
  weekCode     String
  reviewedAt   DateTime @default(now())
  reviewedById String?

  payment    Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("PaymentCashAuditReviewBy", fields: [reviewedById], references: [id])

  @@unique([paymentId, weekCode])
  @@index([weekCode])
  @@index([paymentId])
}

/**
 * בקרת קופה יומית — ספירת קופה בפועל לפי יום (מנהל).
 */
model CashDailyDrawerCount {
  id          String          @id @default(uuid())
  countryCode WorkCountryCode @default(TR)
  weekCode    String
  countDate   String
  cashIls     Decimal?        @db.Decimal(19, 4)
  cashUsd     Decimal?        @db.Decimal(19, 4)
  checksIls   Decimal?        @db.Decimal(19, 4)
  creditIls   Decimal?        @db.Decimal(19, 4)
  transferIls Decimal?        @db.Decimal(19, 4)
  transferUsd Decimal?        @db.Decimal(19, 4)
  creditUsd   Decimal?        @db.Decimal(19, 4)
  checksUsd   Decimal?        @db.Decimal(19, 4)
  otherUsd    Decimal?        @db.Decimal(19, 4)
  otherIls    Decimal?        @db.Decimal(19, 4)
  updatedById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  updatedBy User? @relation("CashDailyDrawerCountBy", fields: [updatedById], references: [id])

  @@unique([countryCode, weekCode, countDate])
  @@index([weekCode])
  @@index([countDate])
}

/**
 * בקרת קופה שבועית — ספירה, רכישת מט"ח, העברה לטורקיה, יתרות.
 */
model CashWeekFlow {
  id                 String          @id @default(uuid())
  countryCode        WorkCountryCode @default(TR)
  weekCode           String
  countedCashIls     Decimal?        @db.Decimal(19, 4)
  countedCashUsd     Decimal?        @db.Decimal(19, 4)
  countedCreditIls   Decimal?        @db.Decimal(19, 4)
  countedChecksIls   Decimal?        @db.Decimal(19, 4)
  countedTransferIls Decimal?        @db.Decimal(19, 4)
  fxPurchaseIls      Decimal?        @db.Decimal(19, 4)
  fxPurchaseUsd      Decimal?        @db.Decimal(19, 4)
  turkeyTransferUsd  Decimal?        @db.Decimal(19, 4)
  bankBalanceIls     Decimal?        @db.Decimal(19, 4)
  bankBalanceUsd     Decimal?        @db.Decimal(19, 4)
  /** עמלות מנהל — שבוע */
  commissionUsd      Decimal?        @db.Decimal(19, 4)
  commissionIls      Decimal?        @db.Decimal(19, 4)
  /** יתרת ₪ אחרי רכישת מט"ח — נשאר בקופה (סכום אחרון / מצטבר) */
  fxRemainderCashIls Decimal?        @db.Decimal(19, 4)
  /** יתרת ₪ אחרי רכישת מט"ח — הועבר לבנק */
  fxRemainderBankIls Decimal?        @db.Decimal(19, 4)
  /** היסטוריית רכישות מט"ח — מערך JSON */
  fxPurchases        Json?
  updatedById        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  updatedBy User? @relation("CashWeekFlowBy", fields: [updatedById], references: [id])
  turkeyTransferMovements TurkeyTransferMovement[]

  @@unique([countryCode, weekCode])
  @@index([weekCode])
}

/** פירוט צ׳קים לקליטת תשלום בצ׳ק — משויך לשורת Payment (בדרך כלל לתשלום הראשי בפיצול להזמנות) */
model PaymentCheck {
  id          String   @id @default(cuid())
  paymentId   String
  countryCode WorkCountryCode @default(TR)
  checkNumber String
  dueDate     DateTime
  amount      Decimal  @db.Decimal(19, 4)
  /** ממתין / הופקד / חזר — ברירת מחדל לרשומות חדשות: ממתין */
  status      PaymentCheckStatus @default(PENDING)
  /** תשלום הפוכה (שלילי) שנוצר בעת סימון ״חזר״ — למניעת כפילות */
  reversalPaymentId String? @unique

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([countryCode])
  @@index([status])
  @@index([dueDate])
}

model ReceiptControl {
  id                 String    @id @default(uuid())
  receiptCode        String?   @unique
  weekCode           String?
  countryCode        WorkCountryCode @default(TR)
  receiptDate        DateTime?
  customerId         String?
  amountUsdExpected  Decimal?  @db.Decimal(19, 4)
  amountUsdReceived  Decimal?  @db.Decimal(19, 4)
  amountIlsExpected  Decimal?  @db.Decimal(19, 4)
  amountIlsReceived  Decimal?  @db.Decimal(19, 4)
  differenceUsd      Decimal?  @db.Decimal(19, 4)
  differenceIls      Decimal?  @db.Decimal(19, 4)
  notes              String?
  createdById        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  customer  Customer? @relation(fields: [customerId], references: [id])
  createdBy User?     @relation("ReceiptControlCreatedBy", fields: [createdById], references: [id])

  @@index([weekCode])
  @@index([countryCode])
  @@index([receiptDate])
  @@index([customerId])
}

model PaymentPoint {
  id            String   @id @default(uuid())
  pointName     String
  city          String?
  region        String?
  address       String?
  contactName   String?
  contactPhone  String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]

  @@index([pointName])
  @@index([city])
  @@index([region])
}

/** מקומות קליטת הזמנה — רשימה מרכזית; שמירה אוטומטית של שמות חדשים */
model IntakeLocation {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

/** טבלת מיקומי הזמנה היסטורית — נשמרת כדי ש-prisma db push לא ימחק אותה */
model OrderLocation {
  id        String   @id
  name      String
  createdAt DateTime @default(now())
  createdBy String?

  @@index([name], map: "OrderLocations_name_idx")
  @@index([createdBy], map: "OrderLocations_createdBy_idx")
  @@map("OrderLocations")
}

model PaymentLocation {
  id        String   @id @default(uuid())
  name      String
  code      String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([isActive])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  actionType String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([actionType])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([entityType, entityId, createdAt])
}

model LegacyRawRow {
  id               String   @id @default(uuid())
  legacyTableName  String
  legacyRecordId   String?
  rawData          Json
  importedById     String?
  importedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  importedBy User? @relation("LegacyImportUser", fields: [importedById], references: [id])

  @@index([legacyTableName])
  @@index([legacyRecordId])
  @@index([importedAt])
}

enum ExcelImportRowStatus {
  PENDING
  VALID
  ERROR
  IMPORTED
}

model ExcelImportFile {
  id             String   @id @default(uuid())
  shipmentNumber String?
  sendDate       DateTime?
  arrivalDate    DateTime?
  totalWeight    Decimal? @db.Decimal(19, 4)
  totalBoxes     Int?
  createdAt      DateTime @default(now())

  rows ExcelImportRow[]

  @@index([createdAt])
}

model ExcelImportRow {
  id           String             @id @default(uuid())
  fileId       String
  rowNumber    Int
  customerName String?
  phone        String?
  city         String?
  boxesCount   Int?
  weight       Decimal?           @db.Decimal(19, 4)
  amountUsd    Decimal?           @db.Decimal(19, 4)
  notes        String?
  status       ExcelImportRowStatus @default(PENDING)
  errorMessage String?
  createdAt    DateTime           @default(now())

  file ExcelImportFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([status])
  @@index([rowNumber])
}

/// SQL-managed table used by balances workflow (created via raw SQL).
model CustomerBalanceStatusOverride {
  customerId     String   @id
  statusOverride String?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())
}

/// SQL-managed table used by source-tables workflow (created via raw SQL).
model SourcePaymentMethod {
  id        String   @id
  nameHe    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

/// SQL-managed payment method catalog (payment_methods — raw SQL workflow).
model PaymentMethodRegistry {
  id        String   @id
  nameHe    String   @map("name_he")
  nameAr    String?  @map("name_ar")
  nameEn    String?  @map("name_en")
  color     String   @default("#64748b")
  icon      String?
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("payment_methods")
}

/// SQL-managed table used by source-tables workflow (created via raw SQL).
model SourceStatus {
  id        String   @id
  nameHe    String
  color     String   @default("info")
  colorHex  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

/// SQL-managed table used by settings workflow (created via raw SQL).
model AdminSystemSettings {
  settingKey   String   @id @map("setting_key")
  settingValue String   @map("setting_value")
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("admin_system_settings")
}

/// SQL-managed import table used by Excel API routes (created via raw SQL).
model ManualImport {
  id          String            @id
  fileName    String?
  importDate  DateTime          @default(now())
  totalRows   Int               @default(0)
  validRows   Int               @default(0)
  errorRows   Int               @default(0)
  status      String            @default("draft")
  createdAt   DateTime          @default(now())
  invalidRows Int               @default(0)
  fileMeta    Json?
  previewRows Json?
  importRows  ManualImportRow[]

  @@index([importDate])
  @@index([status])
  @@map("imports")
}

/// SQL-managed import-rows table used by Excel API routes (created via raw SQL).
model ManualImportRow {
  id           String       @id
  importId     String
  rowNumber    Int
  name         String?
  phone        String?
  city         String?
  boxes        Int?
  weight       Decimal?     @db.Decimal(19, 4)
  amountLeft   Decimal?     @db.Decimal(19, 4)
  amountRight  Decimal?     @db.Decimal(19, 4)
  notes        String?
  status       String       @default("ERROR")
  errorMessage String?
  createdAt    DateTime     @default(now())
  data         Json?
  import       ManualImport @relation(fields: [importId], references: [id], onDelete: Cascade, map: "import_rows_import_fk")

  @@index([importId])
  @@index([rowNumber])
  @@index([status])
  @@map("import_rows")
}

/**
 * הפרשי התאמה / עמלות שנוצרו בתהליך תשלום (אחרי FIFO).
 * תוספת בלבד — לא משנה FinanceEntry / PaymentAllocation / Cashflow קיימים.
 * פעולות סגירה/קיזוז/מחיקה — ארכיטקטורה מוכנה; טרם מיושמות.
 */
enum PaymentAdjustmentReason {
  PAYMENT_SURPLUS
  METHOD_DEVIATION
  BANK_FEE
  FX_DIFF
  ROUNDING
  MANUAL_ADJUST
  OTHER
}

enum PaymentAdjustmentStatus {
  OPEN
  CLOSED
  CANCELLED
}

model PaymentAdjustmentFee {
  id                 String                   @id @default(uuid())
  customerId         String
  /** מסמך מקור (הזמנה) — אם יש */
  orderId            String?
  /** שורת תשלום עודף (orderId=null) שנרשמה לקופה בלי יתרת זכות */
  paymentId          String?
  /** קוד קליטת תשלום ראשי (למשל WGP-P-000092) */
  paymentCaptureCode String?
  /** מספר הזמנה לצפייה מהירה */
  sourceDocumentCode String?
  paymentMethod      String?
  amountUsd          Decimal                  @db.Decimal(19, 4)
  amountIls          Decimal?                 @db.Decimal(19, 4)
  reason             PaymentAdjustmentReason  @default(PAYMENT_SURPLUS)
  status             PaymentAdjustmentStatus  @default(OPEN)
  notes              String?
  /** בחירת משתמש בשמירה: commission | credit וכו׳ */
  userChoice         String?
  createdById        String?
  closedAt           DateTime?
  closedById         String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  customer  Customer @relation(fields: [customerId], references: [id])
  order     Order?   @relation(fields: [orderId], references: [id])
  payment   Payment? @relation(fields: [paymentId], references: [id])
  createdBy User?    @relation("PaymentAdjustmentFeeCreatedBy", fields: [createdById], references: [id])
  closedBy  User?    @relation("PaymentAdjustmentFeeClosedBy", fields: [closedById], references: [id])

  @@index([customerId])
  @@index([orderId])
  @@index([paymentId])
  @@index([paymentCaptureCode])
  @@index([status])
  @@index([reason])
  @@index([createdAt])
  @@index([customerId, status, createdAt])
  @@index([status, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// מודול משלוחים — Shipment Management
// ─────────────────────────────────────────────────────────────────────────────

enum ShipmentStatus {
  NEW            // חדש
  RECEIVED       // נקלט
  ASSIGNED       // שובץ
  IN_TRANSIT     // בדרך
  DELIVERED      // נמסר
  NOT_DELIVERED  // לא נמסר
  RETURNED       // חזר למחסן
  COMPLETED      // הושלם
}

enum ShipmentPaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

/// אצוות / batch של משלוח (Header)
model ShipmentBatch {
  id                    String    @id @default(uuid())
  /// מספר משלוח אוטומטי: SHP-001, SHP-002, ...
  batchNumber           String    @unique
  /// מספר המשלוח כפי שהתקבל בקובץ הספק
  sourceShipmentNumber  String?
  containerNumber       String?
  totalBoxes            Int?
  totalWeight           Decimal?  @db.Decimal(12, 3)
  shippingDate          DateTime?
  arrivalDate           DateTime?
  releaseDate           DateTime?
  warehouseReceiptDate  DateTime?
  distributionStartDate DateTime?
  notes                 String?
  createdById           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  records ShipmentRecord[]

  @@index([batchNumber])
  @@index([createdAt])
  @@map("ShipmentBatch")
}

/// אזור חלוקה — ניתן להגדרה חופשית על ידי המנהל
model ShipmentDeliveryZone {
  id          String   @id @default(uuid())
  name        String   @unique
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())

  records ShipmentRecord[]

  @@index([isActive])
  @@map("ShipmentDeliveryZone")
}

/// שליח קבוע במודול המשלוחים — מנוהל מתוך הגדרות המודול
model ShipmentCourier {
  id          String   @id @default(uuid())
  name        String   @unique
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records ShipmentRecord[]

  @@index([isActive])
  @@map("ShipmentCourier")
}

/// שורת משלוח בודד — נגזרת משורה בקובץ האקסל
model ShipmentRecord {
  id              String                @id @default(uuid())
  batchId         String
  batch           ShipmentBatch         @relation(fields: [batchId], references: [id])
  rowIndex        Int
  customerCode    String?
  customerName    String?
  customerPhone   String?
  address         String?
  city            String?
  boxes           Int?
  cartonDetails   String?
  weight          Decimal?              @db.Decimal(12, 3)
  /// סכום ההזמנה כפי שהתקבל בקובץ — מידע בלבד, אינו משמש לגבייה
  orderAmount         Decimal?           @db.Decimal(19, 4)
  /// מטבע סכום ההזמנה המקורי: ILS | USD | EUR | TRY | GBP | UNKNOWN
  orderCurrency       String?
  /// סכום דמי המשלוח במטבע המקורי של קובץ הספק
  deliveryFeeAmount   Decimal?           @db.Decimal(19, 4)
  /// ILS | USD | EUR | TRY | GBP | UNKNOWN
  deliveryFeeCurrency String?
  /// שדה legacy: מתמלא רק כאשר מטבע דמי המשלוח הוא ILS
  deliveryFeeIls  Decimal?              @db.Decimal(12, 2)
  zoneId          String?
  zone            ShipmentDeliveryZone? @relation(fields: [zoneId], references: [id])
  courierId       String?
  courier         ShipmentCourier?       @relation(fields: [courierId], references: [id])
  /// snapshot/legacy name retained for reports and old rows
  courierName     String?
  status          ShipmentStatus        @default(NEW)
  paymentStatus   ShipmentPaymentStatus @default(UNPAID)
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  payments ShipmentPaymentLine[]

  @@index([batchId])
  @@index([zoneId])
  @@index([courierId])
  @@index([status])
  @@index([paymentStatus])
  @@index([batchId, status])
  @@map("ShipmentRecord")
}

/// שורת תשלום עבור דמי משלוח (אמצעי תשלום אחד לכל שורה)
model ShipmentPaymentLine {
  id               String   @id @default(uuid())
  shipmentRecordId String
  shipment         ShipmentRecord @relation(fields: [shipmentRecordId], references: [id])
  /// אמצעי תשלום: CASH | BANK_TRANSFER | CREDIT | CHECK | BIT | PAYBOX | OTHER
  method           String
  amountIls        Decimal  @db.Decimal(12, 2)
  /// JSON של פרטים ייעודיים לאמצעי התשלום (אסמכתא, בנק, צ'ק, אשראי וכו')
  detailsJson      String?
  notes            String?
  createdById      String?
  updatedById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@index([shipmentRecordId])
  @@map("ShipmentPaymentLine")
}

/// SQL-managed table — מסמכים מצורפים (Document Atlas). נוצרת דרך prisma/sql/documents_table.sql.
model Document {
  id             String    @id @default(uuid())
  /// סוג הישות הקשורה: ORDER | PAYMENT | CUSTOMER | EMPLOYEE | SUPPLIER | TASK | REPORT
  entityType     String
  /// מזהה הישות הקשורה
  entityId       String
  /// תיוג קטגוריית מסמך (אופציונלי): CHECK / TRANSFER / RECEIPT / CONTRACT / ID / ...
  docType        String?
  fileName       String
  bucket         String
  storagePath    String
  mimeType       String
  fileSize       Int       @default(0)
  uploadedById   String?
  uploadedByName String?
  /// סומן אוטומטית כשנוצר ע"י המערכת (PDF הזמנה/תשלום/דוח)
  isAuto         Boolean   @default(false)
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  @@index([entityType, entityId])
  @@index([docType])
  @@index([createdAt])
  @@map("Document")
}

// ─── מודול ספירת מלאי שבועי ──────────────────────────────────────────────────

enum InventoryCountStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

/// מוצר / פריט מלאי — קטלוג הפריטים לספירה
model InventoryItem {
  id           String   @id @default(uuid())
  name         String
  unit         String   @default("יח'")
  pricePerUnit Decimal  @db.Decimal(12, 4)
  currency     String   @default("ILS")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  countLines InventoryCountLine[]

  @@index([isActive])
  @@map("InventoryItem")
}

/// סשן ספירת מלאי שבועי
model InventoryCount {
  id          String               @id @default(uuid())
  weekCode    String
  countDate   DateTime
  status      InventoryCountStatus @default(DRAFT)
  notes       String?
  createdById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  createdBy User?                @relation("InventoryCountCreatedBy", fields: [createdById], references: [id])
  lines     InventoryCountLine[]

  @@index([weekCode])
  @@index([status])
  @@map("InventoryCount")
}

/// שורת ספירה — מוצר × סשן
model InventoryCountLine {
  id         String   @id @default(uuid())
  countId    String
  itemId     String
  systemQty  Decimal  @db.Decimal(12, 3)
  countedQty Decimal  @db.Decimal(12, 3)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  count InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  item  InventoryItem  @relation(fields: [itemId], references: [id])

  @@unique([countId, itemId])
  @@index([countId])
  @@index([itemId])
  @@map("InventoryCountLine")
}
