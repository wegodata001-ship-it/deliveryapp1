// Admin / employee management — data layer only.
// Uses soft deletes where specified; no hard deletes for critical business rows in app logic (enforced later).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum OrderStatus {
  OPEN
  CANCELLED
  WAITING_FOR_EXECUTION
  WITHDRAWAL_FROM_SUPPLIER
  SENT
  WAITING_FOR_CHINA_EXECUTION
  COMPLETED
  DEBT_WITHDRAWAL
}

/** מקור / יעד רכש להזמנה (ניהול וטבלת הזמנות) */
enum OrderSourceCountry {
  TURKEY
  CHINA
  UAE
}

enum OrderEditRequestStatus {
  PENDING
  APPROVED
  REJECTED
  /** נוצלה לאחר עריכה בפועל לאחר אישור */
  USED
}

enum PaymentMethod {
  POINT
  BANK_TRANSFER
  BANK_TRANSFER_DONE
  ORDERED
  WITHDRAWAL
  WITHDRAWAL_DONE
  RECEIVED_AT_POINT
  WITH_GOODS
  CHECK
  CASH
  CREDIT
  OTHER
}

/** סטטוס צ׳יק בקליטה ובטבלת מקור */
enum PaymentCheckStatus {
  PENDING
  DEPOSITED
  BOUNCED
}

model User {
  id           String    @id @default(uuid())
  fullName     String
  email        String?   @unique
  username     String?   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  permissions     UserPermission[]
  createdOrders   Order[]          @relation("OrderCreatedBy")
  createdPayments Payment[]        @relation("PaymentCreatedBy")
  receiptControls ReceiptControl[] @relation("ReceiptControlCreatedBy")
  auditLogs       AuditLog[]
  legacyImports   LegacyRawRow[]    @relation("LegacyImportUser")
  financialSettingsUpdates FinancialSettings[]
  orderEditRequestsRequested OrderEditRequest[] @relation("OrderEditRequestRequestedBy")
  orderEditRequestsApproved  OrderEditRequest[] @relation("OrderEditRequestApprovedBy")
  orderEditRequestsRejected  OrderEditRequest[] @relation("OrderEditRequestRejectedBy")
  ordersEditUnlockedFor      Order[]            @relation("OrderEditUnlockFor")
  notifications              UserNotification[]
}

/** הגדרות שער דולר גלובליות: בסיס (usd_rate_base), עמלה (usd_fee), שער סופי מחושב (usd_rate_final). */
model FinancialSettings {
  id                       String   @id @default(cuid())
  baseDollarRate           Decimal  @db.Decimal(10, 4)
  dollarFee                Decimal  @db.Decimal(10, 4) @default(0)
  finalDollarRate          Decimal  @db.Decimal(10, 4)
  /** אחוז עמלה ברירת מחדל לקליטת הזמנה חדשה (למשל 3.45) */
  defaultCommissionPercent Decimal  @default(0) @db.Decimal(7, 4)
  source                   String   @default("MANUAL")
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedBy User? @relation(fields: [updatedById], references: [id])
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userPermissions UserPermission[]
}

model UserPermission {
  id           String   @id @default(uuid())
  userId       String
  permissionId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

model Customer {
  id              String    @id @default(uuid())
  oldCustomerCode String?
  customerCode    String?   @unique
  nameHe          String?
  nameAr          String?
  nameEn          String?
  displayName     String
  phone           String?
  secondPhone     String?
  email           String?
  city            String?
  region          String?
  address         String?
  notes           String?
  /** סוג לקוח (מערכת ישנה): רגיל / סיטונאי / סוכן וכו׳ */
  customerType    String?
  isActive        Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders          Order[]
  payments        Payment[]
  receiptControls ReceiptControl[]

  @@index([displayName])
  @@index([nameHe])
  @@index([nameAr])
  @@index([nameEn])
  @@index([phone])
  @@index([secondPhone])
  @@index([oldCustomerCode])
}

model Order {
  id                   String         @id @default(uuid())
  oldOrderNumber       String?
  orderNumber          String?        @unique
  customerId           String?
  customerCodeSnapshot String?
  customerNameSnapshot String?
  customerTypeSnapshot String?
  weekCode             String?
  /** מדינת ספק / מקור עסקה — מתוך רשימה מוגדרת בהגדרות */
  sourceCountry        OrderSourceCountry?
  orderDate            DateTime?
  /** תאריך ביצוע ההזמנה בפועל (בתוך טווח השבוע) */
  orderExecutionDate   DateTime?
  /** תאריך ושעת קליטת ההזמנה במערכת */
  intakeDateTime       DateTime?
  status               OrderStatus    @default(OPEN)
  paymentMethod        PaymentMethod?
  paymentPointId       String?
  amountUsd            Decimal?       @db.Decimal(19, 4)
  commissionUsd        Decimal?       @db.Decimal(19, 4)
  totalUsd             Decimal?       @db.Decimal(19, 4)
  amountIls            Decimal?       @db.Decimal(19, 4)
  commissionIls        Decimal?       @db.Decimal(19, 4)
  totalIls             Decimal?       @db.Decimal(19, 4)
  exchangeRate         Decimal?       @db.Decimal(19, 6)
  vatRate              Decimal        @default(18) @db.Decimal(7, 4)
  amountWithoutVat     Decimal?       @db.Decimal(19, 4)
  /** צילום שערים בעת יצירת ההזמנה — לא משתנה כשמעדכנים הגדרות כספים */
  snapshotBaseDollarRate   Decimal? @db.Decimal(10, 4)
  snapshotDollarFee        Decimal? @db.Decimal(10, 4)
  snapshotFinalDollarRate  Decimal? @db.Decimal(10, 4)
  /** שער דולר ששימש לחישוב ₪ לשורה (בדרך כלל = snapshotFinalDollarRate) */
  usdRateUsed              Decimal? @map("usd_rate_used") @db.Decimal(10, 4)
  totalIlsWithVat          Decimal? @db.Decimal(19, 4)
  totalIlsWithoutVat       Decimal? @db.Decimal(19, 4)
  vatAmount                Decimal? @db.Decimal(19, 4)
  notes                String?
  isActive             Boolean        @default(true)
  deletedAt            DateTime?
  createdById          String?
  /** מקום קליטת הזמנה (FK ל-IntakeLocation). נשמר כעמודה רגילה לאחר ALTER TABLE היסטורי. */
  locationId           String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  /**
   * סכום שנמשך אוטומטית מקרדיט הלקוח ("משיכה מהחוב").
   * זה NULL לכל הזמנה רגילה. עבור הזמנה עם status=DEBT_WITHDRAWAL
   * מאוחסן הסכום שנקזז בפועל מיתרת הזכות של הלקוח
   * (≤ totalUsd וגם ≤ הקרדיט הזמין בעת השמירה).
   * לא נוצר Payment עבור הסכום הזה — הוא משפיע על "שולם" של
   * ההזמנה ישירות, ועל יתרת הלקוח דרך orders − payments הקיים.
   */
  debtWithdrawalUsd     Decimal?       @db.Decimal(19, 4)

  customer     Customer?     @relation(fields: [customerId], references: [id])
  createdBy    User?         @relation("OrderCreatedBy", fields: [createdById], references: [id])
  paymentPoint PaymentPoint? @relation(fields: [paymentPointId], references: [id])
  payments    Payment[]
  /** נפתח זמנית לאחר אישור מנהל לעריכת הזמנה בסטטוס הושלמה */
  editUnlockedForUserId String?
  editUnlockedUntil     DateTime?
  editUnlockedFor       User?              @relation("OrderEditUnlockFor", fields: [editUnlockedForUserId], references: [id])
  editRequests          OrderEditRequest[]

  @@index([oldOrderNumber])
  @@index([weekCode])
  @@index([orderDate])
  @@index([orderExecutionDate])
  @@index([intakeDateTime])
  @@index([createdAt])
  @@index([status])
  @@index([customerId])
  @@index([paymentPointId])
  @@index([editUnlockedForUserId])
  @@index([weekCode, deletedAt])
  @@index([sourceCountry])
  @@index([status, orderDate])
}

model OrderEditRequest {
  id                String                 @id @default(uuid())
  orderId           String
  requestedByUserId String
  requestReason     String                 @db.Text
  status            OrderEditRequestStatus @default(PENDING)
  createdAt         DateTime               @default(now())
  approvedAt        DateTime?
  approvedByUserId  String?
  rejectedAt        DateTime?
  rejectedByUserId  String?

  order       Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  requestedBy User  @relation("OrderEditRequestRequestedBy", fields: [requestedByUserId], references: [id])
  approvedBy  User? @relation("OrderEditRequestApprovedBy", fields: [approvedByUserId], references: [id])
  rejectedBy  User? @relation("OrderEditRequestRejectedBy", fields: [rejectedByUserId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([requestedByUserId])
  @@index([createdAt])
}

model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  kind      String
  title     String
  body      String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Payment {
  id               String         @id @default(uuid())
  paymentCode      String?        @unique
  /** מספר קליטה רציף (למשל 92 עבור WGP-P-000092) — ניווט וסדר ERP */
  paymentNumber    Int?
  customerId       String?
  orderId          String?
  weekCode         String?
  paymentDate      DateTime?
  currency         String         @default("ILS")
  amountUsd        Decimal?       @db.Decimal(19, 4)
  amountIls        Decimal?       @db.Decimal(19, 4)
  exchangeRate     Decimal?       @db.Decimal(19, 6)
  vatRate          Decimal        @default(18) @db.Decimal(7, 4)
  /** אחוז עמלה ששמרנו ברגע הקליטה — תצוגתי/תיעודי, אין לו השפעה על amountUsd ואינו שובר חישובים קיימים */
  commissionPercent Decimal       @default(0) @db.Decimal(7, 4)
  amountWithoutVat Decimal?       @db.Decimal(19, 4)
  snapshotBaseDollarRate  Decimal? @db.Decimal(10, 4)
  snapshotDollarFee       Decimal? @db.Decimal(10, 4)
  snapshotFinalDollarRate  Decimal? @db.Decimal(10, 4)
  totalIlsWithVat          Decimal? @db.Decimal(19, 4)
  totalIlsWithoutVat       Decimal? @db.Decimal(19, 4)
  vatAmount                Decimal? @db.Decimal(19, 4)
  manualDateChanged        Boolean  @default(false)
  paymentMethod    PaymentMethod?
  paymentPlace     String?
  isPaid           Boolean        @default(false)
  proofFileUrl     String?
  notes            String?
  createdById      String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  customer  Customer? @relation(fields: [customerId], references: [id])
  order     Order?    @relation(fields: [orderId], references: [id])
  createdBy User?     @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  checks    PaymentCheck[]

  @@index([customerId])
  @@index([orderId])
  @@index([weekCode])
  @@index([paymentDate])
  @@index([createdAt])
  @@index([isPaid])
  @@index([paymentNumber])
  @@index([paymentDate, isPaid])
  @@index([weekCode, isPaid])
}

/** פירוט צ׳קים לקליטת תשלום בצ׳ק — משויך לשורת Payment (בדרך כלל לתשלום הראשי בפיצול להזמנות) */
model PaymentCheck {
  id          String   @id @default(cuid())
  paymentId   String
  checkNumber String
  dueDate     DateTime
  amount      Decimal  @db.Decimal(19, 4)
  /** ממתין / הופקד / חזר — ברירת מחדל לרשומות חדשות: ממתין */
  status      PaymentCheckStatus @default(PENDING)
  /** תשלום הפוכה (שלילי) שנוצר בעת סימון ״חזר״ — למניעת כפילות */
  reversalPaymentId String? @unique

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([status])
  @@index([dueDate])
}

model ReceiptControl {
  id                 String    @id @default(uuid())
  receiptCode        String?   @unique
  weekCode           String?
  receiptDate        DateTime?
  customerId         String?
  amountUsdExpected  Decimal?  @db.Decimal(19, 4)
  amountUsdReceived  Decimal?  @db.Decimal(19, 4)
  amountIlsExpected  Decimal?  @db.Decimal(19, 4)
  amountIlsReceived  Decimal?  @db.Decimal(19, 4)
  differenceUsd      Decimal?  @db.Decimal(19, 4)
  differenceIls      Decimal?  @db.Decimal(19, 4)
  notes              String?
  createdById        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  customer  Customer? @relation(fields: [customerId], references: [id])
  createdBy User?     @relation("ReceiptControlCreatedBy", fields: [createdById], references: [id])

  @@index([weekCode])
  @@index([receiptDate])
  @@index([customerId])
}

model PaymentPoint {
  id            String   @id @default(uuid())
  pointName     String
  city          String?
  region        String?
  address       String?
  contactName   String?
  contactPhone  String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]

  @@index([pointName])
  @@index([city])
  @@index([region])
}

/** מקומות קליטת הזמנה — רשימה מרכזית; שמירה אוטומטית של שמות חדשים */
model IntakeLocation {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

/** טבלת מיקומי הזמנה היסטורית — נשמרת כדי ש-prisma db push לא ימחק אותה */
model OrderLocation {
  id        String   @id
  name      String
  createdAt DateTime @default(now())
  createdBy String?

  @@index([name], map: "OrderLocations_name_idx")
  @@index([createdBy], map: "OrderLocations_createdBy_idx")
  @@map("OrderLocations")
}

model PaymentLocation {
  id        String   @id @default(uuid())
  name      String
  code      String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([isActive])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  actionType String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([actionType])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model LegacyRawRow {
  id               String   @id @default(uuid())
  legacyTableName  String
  legacyRecordId   String?
  rawData          Json
  importedById     String?
  importedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  importedBy User? @relation("LegacyImportUser", fields: [importedById], references: [id])

  @@index([legacyTableName])
  @@index([legacyRecordId])
  @@index([importedAt])
}

enum ExcelImportRowStatus {
  PENDING
  VALID
  ERROR
  IMPORTED
}

model ExcelImportFile {
  id             String   @id @default(uuid())
  shipmentNumber String?
  sendDate       DateTime?
  arrivalDate    DateTime?
  totalWeight    Decimal? @db.Decimal(19, 4)
  totalBoxes     Int?
  createdAt      DateTime @default(now())

  rows ExcelImportRow[]

  @@index([createdAt])
}

model ExcelImportRow {
  id           String             @id @default(uuid())
  fileId       String
  rowNumber    Int
  customerName String?
  phone        String?
  city         String?
  boxesCount   Int?
  weight       Decimal?           @db.Decimal(19, 4)
  amountUsd    Decimal?           @db.Decimal(19, 4)
  notes        String?
  status       ExcelImportRowStatus @default(PENDING)
  errorMessage String?
  createdAt    DateTime           @default(now())

  file ExcelImportFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([status])
  @@index([rowNumber])
}

/// SQL-managed table used by balances workflow (created via raw SQL).
model CustomerBalanceStatusOverride {
  customerId     String   @id
  statusOverride String?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())
}

/// SQL-managed table used by source-tables workflow (created via raw SQL).
model SourcePaymentMethod {
  id        String   @id
  nameHe    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

/// SQL-managed table used by source-tables workflow (created via raw SQL).
model SourceStatus {
  id        String   @id
  nameHe    String
  color     String   @default("info")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

/// SQL-managed table used by settings workflow (created via raw SQL).
model AdminSystemSettings {
  settingKey   String   @id @map("setting_key")
  settingValue String   @map("setting_value")
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("admin_system_settings")
}

/// SQL-managed import table used by Excel API routes (created via raw SQL).
model ManualImport {
  id          String            @id
  fileName    String?
  importDate  DateTime          @default(now())
  totalRows   Int               @default(0)
  validRows   Int               @default(0)
  errorRows   Int               @default(0)
  status      String            @default("draft")
  createdAt   DateTime          @default(now())
  invalidRows Int               @default(0)
  fileMeta    Json?
  previewRows Json?
  importRows  ManualImportRow[]

  @@index([importDate])
  @@index([status])
  @@map("imports")
}

/// SQL-managed import-rows table used by Excel API routes (created via raw SQL).
model ManualImportRow {
  id           String       @id
  importId     String
  rowNumber    Int
  name         String?
  phone        String?
  city         String?
  boxes        Int?
  weight       Decimal?     @db.Decimal(19, 4)
  amountLeft   Decimal?     @db.Decimal(19, 4)
  amountRight  Decimal?     @db.Decimal(19, 4)
  notes        String?
  status       String       @default("ERROR")
  errorMessage String?
  createdAt    DateTime     @default(now())
  data         Json?
  import       ManualImport @relation(fields: [importId], references: [id], onDelete: Cascade, map: "import_rows_import_fk")

  @@index([importId])
  @@index([rowNumber])
  @@index([status])
  @@map("import_rows")
}
